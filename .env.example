# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/teachers-mate

# Server Configuration
PORT=5001

# Clerk Configuration (Frontend)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here
